# =============================================================================
# DVAMOCLES SWORD™: Whiteboard — root ignore (system-agnostic)
# =============================================================================

# --- Environment (never commit secrets) ---
.env
.env.local
.env.*.local
.env.*
!.env.example

# --- OS junk ---
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*~
.directory

# --- Frontend (Vite + React) ---
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/build/
frontend/.vite/
frontend/coverage/
frontend/*.tsbuildinfo
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*

# --- Backend (Python / FastAPI) ---
backend/venv/
backend/.venv/
backend/__pycache__/
backend/**/__pycache__/
backend/*.py[cod]
backend/.pytest_cache/
backend/.mypy_cache/
backend/.ruff_cache/
backend/*.egg-info/
backend/.eggs/

# --- IDEs ---
.vscode/*
!.vscode/extensions.json
.idea/
.cursor/
*.swp
*.swo

# --- Misc ---
*.pem
*.key
.cache/
tmp/
temp/
