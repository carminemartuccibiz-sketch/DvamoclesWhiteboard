# =============================================================================
# DVAMOCLES SWORD™: Whiteboard — system-agnostic ignore rules
# =============================================================================

# --- Node / Frontend (Vite + React) ---
node_modules/
.pnp
.pnp.js

# Vite
.vite/
vite.config.ts.timestamp-*

# Build output
dist/
dist-ssr/
build/
out/
*.tsbuildinfo

# Package manager logs & caches
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store/
.npm/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

# Test / coverage
coverage/
.nyc_output/

# --- Environment variables (never commit secrets) ---
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
.env.*
!.env.example

# --- OS-specific (Windows, macOS, Linux) ---
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.stackdump

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Icon?

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# --- IDEs & editors ---
# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example

# JetBrains
.idea/
*.iml
*.ipr
*.iws

# Cursor
.cursor/
*.cursor-workspace
.cursorrules.local

# Vim / Emacs / Sublime
*.swp
*.swo
*~
\#*\#
.\#*

# Visual Studio
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Backend preparation (Python / FastAPI) ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
.env/
ENV/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
*.egg-info/
.eggs/
dist-python/
*.egg

# --- Misc ---
*.local
*.pem
*.key
.cache/
.temp/
tmp/
temp/
.turbo/
